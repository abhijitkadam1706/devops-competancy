{
  "name": "mern-auth",
  "version": "1.0.0",
  "description": "MERN authentication service — production-grade, AWS DevOps Competency demo",
  "type": "module",
  "main": "api/index.js",
  "scripts": {
    "dev": "nodemon api/index.js",
    "start": "node api/index.js",
    "build": "npm install && npm install --prefix client && npm run build --prefix client",
    "test": "npx vitest run --passWithNoTests --root client",
    "test:coverage": "npx vitest run --coverage --passWithNoTests --root client"
  },
  "keywords": ["mern", "auth", "nodejs", "express", "mongodb"],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.6",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-prom-bundle": "^7.0.0",
    "jsonwebtoken": "^9.0.1",
    "mongoose": "^7.4.2",
    "prom-client": "^15.1.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.1"
  }
}
