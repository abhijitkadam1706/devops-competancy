# =============================================================================
# Terraform-specific .gitignore
# =============================================================================

# Local state files — all state lives in S3 (terraform/global bootstraps it)
.terraform/
terraform.tfstate
terraform.tfstate.backup
.terraform.tfstate.lock.info
crash.log
crash.*.log

# Sensitive variable files
*.tfvars.local
secrets.auto.tfvars

# Generated files
.terraform.lock.hcl

# Override files (local dev only — never commit)
override.tf
override.tf.json
*_override.tf
*_override.tf.json
